# ─── Supabase ─────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Resend (email delivery) ──────────────────────────────────────────────────
# Get your API key at: https://resend.com — free tier: 3,000 emails/month
RESEND_API_KEY=re_your_resend_api_key_here
# Must be a verified domain in your Resend account
RESEND_FROM_EMAIL=protocol@yourdomain.com

# ─── Moon API (Farmsense) ─────────────────────────────────────────────────────
# Get your key at: https://farmsense.net
MOON_API_KEY=your_moon_api_key_here

# ─── Wearable Integration (Terra API) ────────────────────────────────────────
# Get your keys at: https://tryterra.co/dashboard
TERRA_DEV_ID=your_terra_dev_id_here
TERRA_API_KEY=your_terra_api_key_here
# Generate a strong random secret: openssl rand -hex 32
TERRA_WEBHOOK_SECRET=your_terra_webhook_secret_here
